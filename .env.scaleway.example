# Scaleway credentials for optional shared-fs native OS smoke runners.
#
# Copy to `.env.scaleway` for local use. Do not commit real credentials.
# In GitHub Actions, set these as repository secrets instead.
#
# Required:
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
#
# Optional if the Scaleway API key has a default project:
SCALEWAY_PROJECT_ID=
#
# Optional overrides:
SCALEWAY_ZONE=fr-par-1
SCALEWAY_SERVER_TYPE=M2-M
SCALEWAY_WINDOWS_SERVER_TYPE=POP2-2C-8G-WIN
SCALEWAY_WINDOWS_IMAGE=
SCALEWAY_WINDOWS_ROOT_GB=100
#
# SSH key material. For Windows POP2-WIN password encryption, prefer RSA.
PEERBIT_SCALEWAY_SSH_PUBLIC_KEY=
PEERBIT_SCALEWAY_SSH_IDENTITY_FILE=~/.ssh/peerbit_scaleway_rsa
PEERBIT_SCALEWAY_SSH_KEY_ID=
PEERBIT_SCALEWAY_SSH_KEY_NAME=peerbit-gh-runner
#
# Runner behavior:
PEERBIT_RUNNER_EPHEMERAL=1
PEERBIT_SCALEWAY_ENABLE_KEXT=1
PEERBIT_RUNNER_LABELS=peerbit,scaleway
