{
    "private": true,
    "name": "@dao-xyz/peerbit-examples",
    "author": "dao.xyz",
    "repository": "https://github.com/@dao-xyz/peerbit-node",
    "license": "Apache-2.0",
    "type": "module",
    "workspaces": {
        "packages": [
            "packages/**/*",
            "packages/**/**/*"
        ],
        "nohoist": [
            "**/@babel/preset-env",
            "**/@babel/preset-env/**",
            "**/babel-loader",
            "**/babel-loader/**",
            "**/webpack",
            "**/webpack/**",
            "**/svelte-example/**/vite",
            "**/svelte-example/**/vite/**",
            "**/svelte-example/**/vitest",
            "**/svelte-example/**/vitest/**",
            "**/svelte-example/**/@sveltejs/*",
            "**/svelte-example/**/@sveltejs/*/**",
            "**/svelte-example/**/svelte",
            "**/svelte-example/**/svelte/**"
        ]
    },
    "engines": {
        "node": ">=16.15.1"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "clean": "pnpm -r run clean",
        "build": "pnpm -r --sort --workspace-concurrency=1 run build",
        "build-node": "if [ -d ./packages/node ]; then (cd ./packages/node && pnpm run build); else echo \"packages/node not present\"; fi",
        "pub": "pnpm changeset publish",
        "version-packages": "pnpm changeset version && pnpm install --lockfile-only",
        "release:packages": "node scripts/release-packages.mjs",
        "changeset": "changeset",
        "changeset:version": "changeset version",
        "changeset:publish": "changeset publish",
        "test": "pnpm run build && vitest run",
        "test:vitest": "pnpm run build && vitest run",
        "test:vitest:watch": "vitest",
        "test:vitest:quick": "vitest run",
        "test:hosted-apps": "node scripts/validate-hosted-app-runtime.mjs",
        "vitest": "vitest",
        "shared-fs:install:macos": "scripts/install-shared-fs-macos.sh",
        "scaleway:start": "node scripts/github-scaleway-runner.mjs start",
        "scaleway:bootstrap": "node scripts/github-scaleway-runner.mjs bootstrap",
        "scaleway:stop": "node scripts/github-scaleway-runner.mjs stop",
        "scaleway:status": "node scripts/github-scaleway-runner.mjs status",
        "scaleway:janitor": "node scripts/github-scaleway-runner.mjs janitor",
        "scaleway:resources": "node scripts/shared-fs-scaleway-resource-check.mjs",
        "scaleway:windows:start": "node scripts/github-scaleway-windows-runner.mjs start",
        "scaleway:windows:bootstrap": "node scripts/github-scaleway-windows-runner.mjs bootstrap",
        "scaleway:windows:stop": "node scripts/github-scaleway-windows-runner.mjs stop",
        "scaleway:windows:status": "node scripts/github-scaleway-windows-runner.mjs status",
        "scaleway:windows:images": "node scripts/github-scaleway-windows-runner.mjs images",
        "scaleway:windows:janitor": "node scripts/github-scaleway-windows-runner.mjs janitor",
        "scaleway:windows:admin-password": "node scripts/github-scaleway-windows-runner.mjs admin-password",
        "fmt": "prettier --write '{*,**/*}.{js,ts,jsx,tsx,json,vue}'",
        "lint": "eslint --ext .ts . && prettier --check '{*,**/*}.{js,ts,jsx,tsx,json,vue}'",
        "lint:fix": "eslint --fix --ext .ts . && pnpm run fmt",
        "nuke": "shx rm -rf {.,packages/*/*}/{node_modules,yarn.lock}",
        "postinstall": "node scripts/postinstall.mjs"
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.7",
        "@peerbit/stream-interface": "^6.0.11",
        "@playwright/test": "1.58.0",
        "@testing-library/dom": "10.4.1",
        "@testing-library/react": "16.3.0",
        "@types/chai": "^4.3.18",
        "@types/chai-as-promised": "^8",
        "@types/eslint": "^8.40.2",
        "@types/eslint-plugin-prettier": "^3.1.0",
        "@types/node": "^20.5.19",
        "@types/prettier": "^2.4.2",
        "@types/react-test-renderer": "19",
        "@typescript-eslint/eslint-plugin": "^6.16.0",
        "@typescript-eslint/parser": "^6.16.0",
        "chai": "^6.2.0",
        "chai-as-promised": "^8",
        "eslint": "^8.27.0",
        "eslint-config-prettier": "^8.5.0",
        "eslint-config-react-app": "^7.0.1",
        "eslint-plugin-prettier": "^4.2.1",
        "happy-dom": "^20.0.10",
        "jsdom": "^27.0.0",
        "json": "^11.0.0",
        "patch-package": "^8",
        "prettier": "^3.6.2",
        "shx": "^0.3.4",
        "ts-node": "^10.9.1",
        "typescript": "^5.6.3",
        "typescript-esm": "^2.0.0",
        "vitest": "^4.0.8"
    },
    "packageManager": "pnpm@10.26.1+sha512.664074abc367d2c9324fdc18037097ce0a8f126034160f709928e9e9f95d98714347044e5c3164d65bd5da6c59c6be362b107546292a8eecb7999196e5ce58fa"
}
