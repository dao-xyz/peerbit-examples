{
    "private": true,
    "name": "@dao-xyz/peerbit-examples",
    "author": "dao.xyz",
    "repository": "https://github.com/@dao-xyz/peerbit-node",
    "license": "Apache-2.0",
    "type": "module",
    "workspaces": {
        "packages": [
            "packages/**/*",
            "packages/**/**/*"
        ],
        "nohoist": [
            "**/@babel/preset-env",
            "**/@babel/preset-env/**",
            "**/babel-loader",
            "**/babel-loader/**",
            "**/webpack",
            "**/webpack/**",
            "**/svelte-example/**/vite",
            "**/svelte-example/**/vite/**",
            "**/svelte-example/**/vitest",
            "**/svelte-example/**/vitest/**",
            "**/svelte-example/**/@sveltejs/*",
            "**/svelte-example/**/@sveltejs/*/**",
            "**/svelte-example/**/svelte",
            "**/svelte-example/**/svelte/**"
        ]
    },
    "engines": {
        "node": ">=16.15.1"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "clean": "pnpm -r run clean",
        "build": "pnpm -r --sort --workspace-concurrency=1 run build",
        "build-node": "if [ -d ./packages/node ]; then (cd ./packages/node && pnpm run build); else echo \"packages/node not present\"; fi",
        "dev:prod": "pnpm --filter @giga-app/interface-frontend run dev:prod",
        "pub": "pnpm changeset publish",
        "version-packages": "pnpm changeset version",
        "changeset": "changeset",
        "changeset:version": "changeset version",
        "changeset:publish": "changeset publish",
        "test": "pnpm run build && vitest run",
        "test:vitest": "pnpm run build && vitest run",
        "test:vitest:watch": "vitest",
        "test:vitest:quick": "vitest run",
        "vitest": "vitest",
        "fmt": "prettier --write '{*,**/*}.{js,ts,jsx,tsx,json,vue}'",
        "lint": "eslint --ext .ts . && prettier --check '{*,**/*}.{js,ts,jsx,tsx,json,vue}'",
        "lint:fix": "eslint --fix --ext .ts . && pnpm run fmt",
        "nuke": "shx rm -rf {.,packages/*/*}/{node_modules,yarn.lock}",
        "postinstall": "patch-package && mkdir -p node_modules/chai-extend && cp chai-global.js node_modules/chai-extend/chai-global.js && echo '{\"type\": \"module\"}' > node_modules/chai-extend/package.json",
        "e2e:placeholderDelay": "pnpm --filter @giga-app/interface run build && cd packages/social-media-app/frontend && npx playwright test tests/placeholderDelay.spec.ts --reporter=line --timeout=70000",
        "test:frontend:unit": "vitest run -c packages/social-media-app/frontend/vitest.config.ts",
        "prefetch:update": "pnpm --filter @giga-app/interface-frontend run prefetch:update"
    },
    "pnpm": {
        "overrides": {
            "libsodium": "0.7.15",
            "libsodium-wrappers": "0.7.15",
            "@peerbit/any-store": "2.2.4-14881a0",
            "@peerbit/any-store-interface": "1.1.0-14881a0",
            "@peerbit/any-store-opfs": "1.1.3-14881a0",
            "@peerbit/any-store-proxy": "1.0.4-14881a0",
            "@peerbit/blocks": "3.1.8-14881a0",
            "@peerbit/blocks-interface": "1.5.2-14881a0",
            "@peerbit/build-assets": "1.1.0-14881a0",
            "@peerbit/cache": "2.2.0-14881a0",
            "@peerbit/canonical-client": "1.1.2-14881a0",
            "@peerbit/canonical-host": "1.0.4-14881a0",
            "@peerbit/canonical-transport": "1.0.0-14881a0",
            "@peerbit/clock-service": "3.2.23-14881a0",
            "@peerbit/crypto": "2.4.1-14881a0",
            "@peerbit/document": "12.3.5-14881a0",
            "@peerbit/document-interface": "3.2.4-14881a0",
            "@peerbit/document-proxy": "1.0.6-14881a0",
            "@peerbit/document-react": "0.6.6-14881a0",
            "@peerbit/identity-access-controller": "5.3.6-14881a0",
            "@peerbit/indexer-cache": "0.2.2-14881a0",
            "@peerbit/indexer-interface": "2.1.1-14881a0",
            "@peerbit/indexer-simple": "1.2.2-14881a0",
            "@peerbit/indexer-sqlite3": "2.1.2-14881a0",
            "@peerbit/indexer-tests": "2.0.1-14881a0",
            "@peerbit/keychain": "1.2.4-14881a0",
            "@peerbit/libp2p-test-utils": "2.2.0-14881a0",
            "@peerbit/log": "5.0.10-14881a0",
            "@peerbit/logger": "2.0.0-14881a0",
            "@peerbit/program": "5.6.3-14881a0",
            "@peerbit/program-react": "0.4.2-14881a0",
            "@peerbit/pubsub": "4.1.4-14881a0",
            "@peerbit/pubsub-interface": "4.1.2-14881a0",
            "@peerbit/react": "0.2.3-14881a0",
            "@peerbit/riblt": "1.2.0-14881a0",
            "@peerbit/rpc": "5.4.20-14881a0",
            "@peerbit/server": "5.10.14-14881a0",
            "@peerbit/shared-log": "12.3.5-14881a0",
            "@peerbit/shared-log-proxy": "1.0.6-14881a0",
            "@peerbit/stream": "4.6.0-14881a0",
            "@peerbit/stream-interface": "5.4.0-14881a0",
            "@peerbit/string": "5.1.22-14881a0",
            "@peerbit/test-lib": "0.0.1-14881a0",
            "@peerbit/test-utils": "2.3.19-14881a0",
            "@peerbit/time": "2.3.0-14881a0",
            "@peerbit/trusted-network": "5.1.6-14881a0",
            "@peerbit/vite": "1.1.11-14881a0",
            "peerbit": "4.4.19-14881a0"
        }
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.7",
        "@testing-library/dom": "10.4.1",
        "@testing-library/react": "16.3.0",
        "@types/chai": "^4.3.18",
        "@types/chai-as-promised": "^8",
        "@types/eslint": "^8.40.2",
        "@types/eslint-plugin-prettier": "^3.1.0",
        "@types/node": "^20.5.19",
        "@types/prettier": "^2.4.2",
        "@types/react-test-renderer": "19",
        "@typescript-eslint/eslint-plugin": "^6.16.0",
        "@typescript-eslint/parser": "^6.16.0",
        "chai": "^6.2.0",
        "chai-as-promised": "^8",
        "eslint": "^8.27.0",
        "eslint-config-prettier": "^8.5.0",
        "eslint-config-react-app": "^7.0.1",
        "eslint-plugin-prettier": "^4.2.1",
        "happy-dom": "^20.0.10",
        "jsdom": "^27.0.0",
        "json": "^11.0.0",
        "patch-package": "^8",
        "prettier": "^3.6.2",
        "shx": "^0.3.4",
        "ts-node": "^10.9.1",
        "typescript": "^5.6.3",
        "typescript-esm": "^2.0.0",
        "vitest": "^4.0.8"
    },
    "packageManager": "pnpm@10.26.1+sha512.664074abc367d2c9324fdc18037097ce0a8f126034160f709928e9e9f95d98714347044e5c3164d65bd5da6c59c6be362b107546292a8eecb7999196e5ce58fa"
}
