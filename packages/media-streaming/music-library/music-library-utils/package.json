{
    "name": "@peerbit/music-library-utils",
    "version": "2.0.2",
    "author": "Peerbit contributors",
    "repository": "https://github.com/dao-xyz/peerbit-examples",
    "license": "Apache-2.0",
    "type": "module",
    "private": false,
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": false,
    "module": "lib/esm/index.js",
    "types": "lib/esm/index.d.ts",
    "exports": {
        ".": {
            "import": "./lib/esm/index.js",
            "types": "./lib/esm/index.d.ts"
        }
    },
    "files": [
        "lib",
        "src",
        "!src/**/__tests__",
        "!lib/**/__tests__",
        "LICENSE"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "clean": "shx rm -rf lib/*",
        "build": "pnpm run clean && tsc -p tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "test-replicator": "npm run build && node ./lib/esm/__tests__/replicator-node.js",
        "test-replicator-remote": "npm run build && node ./lib/esm/__tests__/replicator-node-remote.js"
    },
    "devDependencies": {
        "@peerbit/test-utils": "^3.1.8",
        "@peerbit/time": "^3.0.1",
        "peerbit": "^5.3.8",
        "typescript": "^5.6.3"
    },
    "dependencies": {
        "@dao-xyz/borsh": "^6.0.0",
        "@peerbit/crypto": "^3.1.4",
        "@peerbit/document": "^13.1.10",
        "@peerbit/media-streaming": "workspace:*",
        "@peerbit/program": "^6.0.37"
    }
}
