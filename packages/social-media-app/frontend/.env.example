# Supabase (for optional sign-in + backing up your Peerbit identity)
#
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# Never put a Supabase "service role" key in here.
# Auth is opt-in. Enabling it requires a deliberately provisioned Peerbit-owned
# project; Cloudflare preview and production builds always keep it disabled.

VITE_SUPABASE_AUTH_ENABLED=false
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional curated-app overrides, useful for preview deployments.
VITE_STREAMING_APP_URL=
VITE_CHESS_APP_URL=

# Optional: E2E test credentials (used by Playwright auth tests)
# TEST_EMAIL=
# TEST_PASSWORD=
TEST_EMAIL=
TEST_PASSWORD=
