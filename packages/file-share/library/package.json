{
    "name": "@peerbit/please-lib",
    "version": "2.0.5",
    "author": "dao.xyz",
    "repository": "https://github.com/@dao-xyz/peerbit-examples",
    "license": "Apache-2.0",
    "type": "module",
    "private": false,
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": false,
    "module": "lib/esm/index.js",
    "types": "lib/esm/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/esm/index.d.ts",
            "import": "./lib/esm/index.js"
        }
    },
    "files": [
        "lib",
        "src",
        "!src/**/__tests__",
        "!lib/**/__tests__",
        "LICENSE"
    ],
    "engines": {
        "node": ">=16.15.1"
    },
    "scripts": {
        "clean": "shx rm -rf lib/*",
        "build": "pnpm run clean && tsc -p tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@peerbit/test-utils": "^3.0.24",
        "typescript": "^5.6.3"
    },
    "dependencies": {
        "@dao-xyz/borsh": "^6.0.0",
        "@peerbit/document": "13.0.30",
        "@peerbit/program": "6.0.20",
        "@peerbit/shared-log": "13.1.4",
        "@peerbit/trusted-network": "6.0.30",
        "@stablelib/sha256": "^2.0.1",
        "peerbit": "^5.2.9",
        "uint8arrays": "^5.1.0",
        "uuid": "^10.0.0"
    }
}
