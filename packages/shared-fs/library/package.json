    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "clean": "shx rm -rf lib/*",
        "build": "pnpm run clean && tsc -p tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@peerbit/test-utils": "^3.0.34",
        "typescript": "^5.6.3"
    },
    "dependencies": {
        "@dao-xyz/borsh": "^6.0.0",
        "@peerbit/crypto": "^3",
        "@peerbit/document": "^13.0.43",
        "@peerbit/program": "^6.0.30",
        "peerbit": "^5.2.19",
        "uint8arrays": "^5.1.0"
    }
}
