{
    "name": "@peerbit/shared-fs",
    "version": "0.0.1",
    "author": "dao.xyz",
    "repository": "https://github.com/@dao-xyz/peerbit-examples",
    "license": "Apache-2.0",
    "type": "module",
    "private": false,
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": false,
    "module": "lib/esm/index.js",
    "types": "lib/esm/index.d.ts",
